# ── Zabbix connection ─────────────────────────────────────────────────────────

ZABBIX_URL=https://zabbix.example.com
ZABBIX_VERIFY_SSL=true

# ── Authentication ────────────────────────────────────────────────────────────

# API token (recommended — Zabbix 5.4+)
# Create one at: Administration → Users → your user → API tokens
ZABBIX_TOKEN=your_api_token_here

# User / password (alternative — remove ZABBIX_TOKEN if using this)
# ZABBIX_USER=Admin
# ZABBIX_PASSWORD=zabbix

# ── Agent: LLM provider ───────────────────────────────────────────────────────

# Active provider: nvidia | openrouter | groq  (default: nvidia)
ZABBIX_MCP_PROVIDER=nvidia

# NVIDIA Build (https://build.nvidia.com → get API key)
ZABBIX_MCP_NVIDIA_API_KEY=nvapi-...
ZABBIX_MCP_NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenRouter (alternative)
# ZABBIX_MCP_OPENROUTER_API_KEY=sk-or-...
# ZABBIX_MCP_OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Groq (alternative)
# ZABBIX_MCP_GROQ_API_KEY=gsk_...
# ZABBIX_MCP_GROQ_MODEL=llama-3.3-70b-versatile

# ── MCP transport ─────────────────────────────────────────────────────────────

# stdio  — JSON-RPC 2.0 over stdin/stdout (default, used by Claude Desktop and agents)
# sse    — HTTP/SSE server on MCP_HOST:MCP_PORT
MCP_TRANSPORT=stdio

# Bind address and port — only used when MCP_TRANSPORT=sse
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
